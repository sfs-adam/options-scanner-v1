# Options Scanner v1 — Environment Variables
# Copy this file to .env and fill in your values.

# Polygon.io API key (required for daily OHLCV history)
# Get one free at https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Optional: HTTP proxy if on a corporate network
# HTTPS_PROXY=http://proxy.example.com:8080

# Optional: change the local port (default 8001)
# PORT=8001
